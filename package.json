{
  "devDependencies": {
    "daisyui": "^4.12.24",
    "htmx.org": "^2.0.10",
    "tailwindcss": "^3.4.19",
    "wrangler": "4.110.0"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./internal/httpapi/assets/app.css -o ./internal/httpapi/static/macftpd.css --minify",
    "prepare:assets": "mkdir -p internal/httpapi/static && cp node_modules/htmx.org/dist/htmx.min.js internal/httpapi/static/htmx.min.js",
    "build": "npm run prepare:assets && npm run build:css"
  },
  "name": "macftpd",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Frontend asset build for macftpd"
}
